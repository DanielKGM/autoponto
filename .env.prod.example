# ==========================================
# CONFIGURAÇÕES PRINCIPAIS (DJANGO)
# ==========================================

# ⚠️ [PREENCHER] Sensível: gere uma chave única e longa na VM antes de subir.
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=

DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=cidadesinteligentes.lsdi.ufma.br,192.168.10.104,localhost,127.0.0.1
TIME_ZONE=America/Sao_Paulo

# ==========================================
# SEGURANÇA E CORS
# ==========================================
CORS_ALLOWED_ORIGINS=https://cidadesinteligentes.lsdi.ufma.br
CSRF_TRUSTED_ORIGINS=https://cidadesinteligentes.lsdi.ufma.br

# ==========================================
# BANCO DE DADOS (POSTGRESQL)
# ==========================================
DATABASE_NAME=autoponto
DATABASE_USER=autoponto

# ⚠️ [PREENCHER] Sensível: defina a senha real do PostgreSQL na VM.
DATABASE_PASSWORD=

DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_CONNECT_TIMEOUT_SECONDS=5

# ==========================================
# AUTENTICAÇÃO E SESSÃO (JWT & TOKENS)
# ==========================================
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=1
JWT_REFRESH_COOKIE_NAME=autoponto_refresh
JWT_REFRESH_COOKIE_PATH=/interscity_lh/catalog/autoponto/api/auth/
JWT_REFRESH_COOKIE_SECURE=True
JWT_REFRESH_COOKIE_SAMESITE=Lax
NODE_TOKEN_EXPIRATION_DAYS=90

# ==========================================
# RECONHECIMENTO FACIAL E IA
# ==========================================

# ⚠️ [PREENCHER] Sensível: Chave de criptografia dos embeddings faciais.
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FACE_EMBEDDING_ENCRYPTION_KEY=

FACE_DETECT_MODEL_PATH=data/models/face_detection_yunet.onnx
FACE_RECOG_MODEL_PATH=data/models/face_recognition_sface.onnx
FACE_SCORE_THRESHOLD=0.8
FACE_DUPLICATE_THRESHOLD=0.363
FACE_MAX_CAPTURAS=5
FACE_MAX_IMAGE_BYTES=20971520
FACE_MAX_IMAGE_PIXELS=50000000

# ==========================================
# CACHE (REDIS)
# ==========================================
FACE_EMBEDDING_CACHE_URL=redis://redis:6379/0

# ⚠️ [PREENCHER] Sensível: Defina a senha do Redis na VM.
FACE_EMBEDDING_CACHE_PASSWORD=

# ==========================================
# INTEGRACAO INTERSCITY
# ==========================================
INTERSCITY_BASE_URL=https://cidadesinteligentes.lsdi.ufma.br/interscity_lh
INTERSCITY_COLLECTOR_PATH=/collector
INTERSCITY_TIMEOUT_SECONDS=5

# ==========================================
# EVIDENCIAS E METRICAS PARA O TCC
# ==========================================
TCC_EVIDENCIAS_ENABLED=False
TCC_EVIDENCIAS_DIR=/data/logs/tcc

# ==========================================
# DOCUMENTAÇÃO DA API (SWAGGER/REDOC)
# ==========================================
PUBLIC_API_DOCS=True
API_DOCS_SERVER_URL=/interscity_lh/catalog/autoponto

# ==========================================
# FRONTEND (VITE)
# ==========================================
VITE_BASE_PATH=/interscity_lh/catalog/autoponto/
VITE_API_URL=/interscity_lh/catalog/autoponto/api
